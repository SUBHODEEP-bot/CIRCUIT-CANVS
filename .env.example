# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_public_key_here

# Supabase Service Keys (for backend)
SUPABASE_SERVICE_KEY=your_supabase_service_key_here
SUPABASE_SERVICE_ROLE=your_supabase_service_role_key_here

# Admin Credentials
ADMIN_NAME=admin
ADMIN_PASSWORD=your_secure_password_here

# Frontend Environment Variables (also needed in circuit-canvas/.env)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_public_key_here

# Optional Gemini/Generative Language API (used by admin AI mapping)
# Obtain a key from Google Cloud and do NOT commit it to source control
GEMINI_API_KEY=your_gemini_api_key_here
# Example models: gemini-1.5-pro, gemini-1.5-mini, etc.
GEMINI_MODEL=gemini-1.5-pro
# You can override the endpoint/method if necessary:
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_API_METHOD=generateContent
